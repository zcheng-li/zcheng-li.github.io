      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/docs/cv/</guid>
      <description>&lt;section class=&#34;cv-codepage&#34;&gt;&#xA;  &lt;header class=&#34;cv-head&#34;&gt;&#xA;    &lt;div class=&#34;cv-window-dots&#34; aria-hidden=&#34;true&#34;&gt;&#xA;      &lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;    &lt;p class=&#34;cv-file&#34;&gt;resume.cs&lt;/p&gt;&#xA;  &lt;/header&gt;&#xA;&#xA;  &lt;div class=&#34;cv-grid&#34;&gt;&#xA;    &lt;aside class=&#34;cv-left&#34;&gt;&#xA;      &lt;div class=&#34;cv-photo-wrap&#34;&gt;&#xA;        &lt;img src=&#34;http://localhost:1313/images/cv-avatar.svg&#34; alt=&#34;Profile photo&#34; class=&#34;cv-photo&#34; /&gt;&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;kw&#34;&gt;public enum&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;PLATFORMS&lt;/span&gt;()&#xA;{&#xA;  Windows,&#xA;  Linux,&#xA;  macOS&#xA;}&#xA;&#xA;&lt;span class=&#34;kw&#34;&gt;public enum&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;SKILLS&lt;/span&gt;()&#xA;{&#xA;  C++, Python, SQL,&#xA;  PyTorch, ROS2,&#xA;  HTML, CSS, JS&#xA;}&#xA;&#xA;&lt;span class=&#34;kw&#34;&gt;public enum&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;MEDIA&lt;/span&gt;()&#xA;{&#xA;  GitHub,&#xA;  LinkedIn,&#xA;  Email,&#xA;  CV(PDF)&#xA;}&lt;/code&gt;&lt;/pre&gt;&#xA;    &lt;/aside&gt;&#xA;&#xA;    &lt;main class=&#34;cv-main&#34;&gt;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;comment&#34;&gt;/// &amp;lt;summary&amp;gt;&lt;/span&gt;&#xA;&lt;span class=&#34;comment&#34;&gt;/// 机器人工程/软件开发方向，偏好 C++ 与 Python。&lt;/span&gt;&#xA;&lt;span class=&#34;comment&#34;&gt;/// 关注工程化、可维护性和实际落地。&lt;/span&gt;&#xA;&lt;span class=&#34;comment&#34;&gt;/// &amp;lt;/summary&amp;gt;&lt;/span&gt;&#xA;&lt;span class=&#34;kw&#34;&gt;public class&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;PROFILE&lt;/span&gt;&#xA;{&#xA;  &lt;span class=&#34;kw&#34;&gt;public string&lt;/span&gt; &lt;span class=&#34;prop&#34;&gt;NAME&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;Your Name&#34;&lt;/span&gt;;&#xA;  &lt;span class=&#34;kw&#34;&gt;public string&lt;/span&gt; &lt;span class=&#34;prop&#34;&gt;TITLE&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;Robotics / Software Engineer&#34;&lt;/span&gt;;&#xA;  &lt;span class=&#34;kw&#34;&gt;public string&lt;/span&gt; &lt;span class=&#34;prop&#34;&gt;EMAIL&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;you@example.com&#34;&lt;/span&gt;;&#xA;  &lt;span class=&#34;kw&#34;&gt;public string&lt;/span&gt; &lt;span class=&#34;prop&#34;&gt;LOCATION&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;London, UK&#34;&lt;/span&gt;;&#xA;}&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;kw&#34;&gt;public static class&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;EXPERIENCE&lt;/span&gt;&#xA;{&#xA;  &lt;span class=&#34;kw&#34;&gt;public void&lt;/span&gt; &lt;span class=&#34;fn&#34;&gt;ResearchAssistant&lt;/span&gt;()&#xA;  {&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Date = &lt;span class=&#34;str&#34;&gt;&#34;2024.09 - Present&#34;&lt;/span&gt;;&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Focus = &lt;span class=&#34;str&#34;&gt;&#34;Perception, control, model deployment&#34;&lt;/span&gt;;&#xA;  }&#xA;&#xA;  &lt;span class=&#34;kw&#34;&gt;public void&lt;/span&gt; &lt;span class=&#34;fn&#34;&gt;ProjectLead&lt;/span&gt;()&#xA;  {&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Date = &lt;span class=&#34;str&#34;&gt;&#34;2023.02 - 2024.06&#34;&lt;/span&gt;;&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Outcome = &lt;span class=&#34;str&#34;&gt;&#34;Shipped end-to-end demo with CI pipeline&#34;&lt;/span&gt;;&#xA;  }&#xA;}&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;kw&#34;&gt;public partial class&lt;/span&gt; &lt;span class=&#34;type&#34;&gt;EDUCATION&lt;/span&gt;&#xA;{&#xA;  &lt;span class=&#34;kw&#34;&gt;private void&lt;/span&gt; &lt;span class=&#34;fn&#34;&gt;MasterDegree&lt;/span&gt;()&#xA;  {&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _School = &lt;span class=&#34;str&#34;&gt;&#34;Your University&#34;&lt;/span&gt;;&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Program = &lt;span class=&#34;str&#34;&gt;&#34;MSc in Robotics / AI&#34;&lt;/span&gt;;&#xA;    &lt;span class=&#34;kw&#34;&gt;var&lt;/span&gt; _Date = &lt;span class=&#34;str&#34;&gt;&#34;2024 - 2026&#34;&lt;/span&gt;;&#xA;  }&#xA;}&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;      &lt;div class=&#34;cv-links&#34;&gt;&#xA;        &lt;a href=&#34;https://github.com/yourname&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;GitHub&lt;/a&gt;&#xA;        &lt;a href=&#34;https://www.linkedin.com/in/yourname&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;LinkedIn&lt;/a&gt;&#xA;        &lt;a href=&#34;mailto:you@example.com&#34;&gt;Email&lt;/a&gt;&#xA;        &lt;a href=&#34;http://localhost:1313/files/cv.pdf&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;Download CV&lt;/a&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/main&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/section&gt;</description>
    </item>
    <item>
