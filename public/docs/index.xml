      <description>&lt;section class=&#34;cv-codepage&#34;&gt;&#xA;  &lt;header class=&#34;cv-head&#34;&gt;&#xA;    &lt;div class=&#34;cv-window-dots&#34; aria-hidden=&#34;true&#34;&gt;&#xA;      &lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;    &lt;p class=&#34;cv-file&#34;&gt;resume.py&lt;/p&gt;&#xA;  &lt;/header&gt;&#xA;&#xA;  &lt;div class=&#34;cv-grid&#34;&gt;&#xA;    &lt;aside class=&#34;cv-left&#34;&gt;&#xA;      &lt;div class=&#34;cv-photo-wrap&#34;&gt;&#xA;        &lt;img src=&#34;http://localhost:1313/img/cv-avatar.jpg&#34; alt=&#34;Profile photo&#34; class=&#34;cv-photo&#34; /&gt;&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;comment&#34;&gt;# Contact&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;name&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;Zhicheng Li&#34;&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;location&lt;/span&gt; = [&lt;span class=&#34;str&#34;&gt;&#34;Chengdu, China&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;Glasgow, UK&#34;&lt;/span&gt;]&#xA;&lt;span class=&#34;var&#34;&gt;email&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;zcheng.li@outlook.com&#34;&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;github&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;github.com/zcheng-li&#34;&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;linkedin&lt;/span&gt; = &lt;span class=&#34;str&#34;&gt;&#34;www.linkedin.com/in/zhicheng-li-3547b8322&#34;&lt;/span&gt;&#xA;&#xA;&lt;span class=&#34;comment&#34;&gt;# Languages&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;languages&lt;/span&gt; = {&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Chinese&#34;&lt;/span&gt;: .native,&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;English&#34;&lt;/span&gt;: .fluent,&#xA;}&#xA;&#xA;&lt;span class=&#34;comment&#34;&gt;# Programming&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;tech_stack&lt;/span&gt; = [&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Python&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;C&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;C++&#34;&lt;/span&gt;, &#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Matlab&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;Swift&#34;&lt;/span&gt;, &#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Bash&#34;&lt;/span&gt;&#xA;]&#xA;&#xA;&lt;span class=&#34;comment&#34;&gt;# Platforms&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;platforms&lt;/span&gt; = [&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;macOS&#34;&lt;/span&gt;, &#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Windows&#34;&lt;/span&gt;, &#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Linux&#34;&lt;/span&gt;&#xA;]&#xA;&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;comment&#34;&gt;# Hobbies&lt;/span&gt;&#xA;&lt;span class=&#34;var&#34;&gt;hobbies&lt;/span&gt; = [&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Bouldering&#34;&lt;/span&gt;,&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;Hiking&#34;&lt;/span&gt;,&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;App Development&#34;&lt;/span&gt;,&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;3D Modeling&#34;&lt;/span&gt;,&#xA;    &lt;span class=&#34;str&#34;&gt;&#34;sci-fi&#34;&lt;/span&gt;&#xA;]&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;    &lt;/aside&gt;&#xA;&#xA;    &lt;main class=&#34;cv-main&#34;&gt;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;kw&#34;&gt;from&lt;/span&gt; &lt;span class=&#34;name&#34;&gt;dataclasses&lt;/span&gt; &lt;span class=&#34;kw&#34;&gt;import&lt;/span&gt; &lt;span class=&#34;name&#34;&gt;dataclass&lt;/span&gt;&#xA;&#xA;&lt;span class=&#34;decor&#34;&gt;@dataclass&lt;/span&gt;&#xA;&lt;span class=&#34;kw&#34;&gt;class&lt;/span&gt; &lt;span class=&#34;name&#34;&gt;Education&lt;/span&gt;:&#xA;    &lt;span class=&#34;var&#34;&gt;university&lt;/span&gt;: &lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;&#xA;    &lt;span class=&#34;var&#34;&gt;program&lt;/span&gt;: &lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;&#xA;    &lt;span class=&#34;var&#34;&gt;period&lt;/span&gt;: &lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;&#xA;    &lt;span class=&#34;var&#34;&gt;location&lt;/span&gt;: &lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;&#xA;    &lt;span class=&#34;var&#34;&gt;notes&lt;/span&gt;: &lt;span class=&#34;name&#34;&gt;list&lt;/span&gt;[&lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;]&#xA;&#xA;&lt;span class=&#34;var&#34;&gt;education&lt;/span&gt; = [&#xA;    &lt;span class=&#34;name&#34;&gt;Education&lt;/span&gt;(&#xA;        &lt;span class=&#34;var&#34;&gt;university&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;University of Electronic Science and Technology of China&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;program&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;Bachelor of Electronic Information Engineering&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;period&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;2022-2026&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;location&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;Chengdu, China&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;notes&lt;/span&gt;=[&#xA;            &lt;span class=&#34;str&#34;&gt;&#34;GPA: 3.78/4.0&#34;&lt;/span&gt;,&#xA;            &lt;span class=&#34;str&#34;&gt;&#34;Accumulated Grade Average: 87.87/100&#34;&lt;/span&gt;,&#xA;            &lt;span class=&#34;str&#34;&gt;&#34;Rank: 9/241&#34;&lt;/span&gt;,&#xA;        ],&#xA;    ),&#xA;    &lt;span class=&#34;name&#34;&gt;Education&lt;/span&gt;(&#xA;        &lt;span class=&#34;var&#34;&gt;university&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;University of Glasgow (Joint-Degree Program)&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;program&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;Bachelor of Electronic and Electricity Engineering (Estimate: 1:1)&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;period&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;2024-2026&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;location&lt;/span&gt;=&lt;span class=&#34;str&#34;&gt;&#34;Glasgow, UK&#34;&lt;/span&gt;,&#xA;        &lt;span class=&#34;var&#34;&gt;notes&lt;/span&gt;=[&#xA;            &lt;span class=&#34;str&#34;&gt;&#34;GPA: 20.0/22.0&#34;&lt;/span&gt;,&#xA;            &lt;span class=&#34;str&#34;&gt;&#34;Degree: 1:1 (esitimated)&#34;&lt;/span&gt;,&#xA;            ],&#xA;    ),&#xA;]&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;      &lt;pre class=&#34;cv-block&#34;&gt;&lt;code&gt;&lt;span class=&#34;kw&#34;&gt;def&lt;/span&gt; &lt;span class=&#34;fn&#34;&gt;awards_and_honors&lt;/span&gt;() -&gt; &lt;span class=&#34;name&#34;&gt;list&lt;/span&gt;[&lt;span class=&#34;name&#34;&gt;tuple&lt;/span&gt;[&lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;, &lt;span class=&#34;name&#34;&gt;str&lt;/span&gt;]]:&#xA;    &lt;span class=&#34;kw&#34;&gt;return&lt;/span&gt; [&#xA;        (&lt;span class=&#34;str&#34;&gt;&#34;Scholarship for Excellent Student of UESTC&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;2023 &amp;amp; 2024&#34;&lt;/span&gt;),&#xA;        (&lt;span class=&#34;str&#34;&gt;&#34;Excellent Student Club Leader at UESTC&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;2024&#34;&lt;/span&gt;),&#xA;        (&lt;span class=&#34;str&#34;&gt;&#34;Academic Scholarship (Top 10%)&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;2023 &amp;amp; 2024&#34;&lt;/span&gt;),&#xA;        (&lt;span class=&#34;str&#34;&gt;&#34;Apple Swift Student Challenge Winner&#34;&lt;/span&gt;, &lt;span class=&#34;str&#34;&gt;&#34;2024&#34;&lt;/span&gt;),&#xA;    ]&lt;/code&gt;&lt;/pre&gt;&#xA;    &lt;/main&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/section&gt;</description>
    </item>
